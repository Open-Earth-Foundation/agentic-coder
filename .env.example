# Required
ANTHROPIC_API_KEY=sk-ant-...
REPO_PATH=../CityCatalyst
BRANCH_PREFIX=agentic-coder
BASE_BRANCH=develop

# Jira (optional — needed for ./run.sh jira)
# JIRA_DOMAIN=yourcompany.atlassian.net
# JIRA_EMAIL=you@company.com
# JIRA_API_TOKEN=your-jira-api-token
# JIRA_PROJECT=CC
# JIRA_AGENT_LABEL=agent-ready

# Notion (optional — needed for ./run.sh notion)
# NOTION_API_KEY=secret_...
# NOTION_DATABASE_ID=your-database-id

# Linear (optional — needed for ./run.sh linear)
# LINEAR_API_KEY=lin_api_...
# LINEAR_TEAM_ID=bab8bb25-61da-4863-a960-fb33d4dd4f0f
# LINEAR_AGENT_LABEL=agent-ready
